    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "pg": "^8.22.0",
    "postgres": "^3.4.9",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.1",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.10",
    "supertest": "^7.2.2",
    "ts-node-dev": "^2.0.0",
